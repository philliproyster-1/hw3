<h1><%= @place.name %></h1>

<p><a href="/places">Back to Places</a></p>

<% @entries.each do |entry| %>
  <h3><%= entry.title %></h3>
  <p style="font-size: 0.9em; color: #555;"><%= entry.posted_on %></p>
  <p><%= entry.description %></p>
  <br>
<% end %>

<p><a href="/entries/new?place_id=<%= @place.id %>">New Post</a></p>